# Default RADIUS virtual server configuration
# Optimized for high performance with 2000+ concurrent users

# Listen on all interfaces for maximum compatibility
listen {
    type = auth
    ipaddr = *
    port = 1812
    limit {
        max_connections = 2048
        lifetime = 0
        idle_timeout = 30
    }
}

listen {
    type = acct
    ipaddr = *
    port = 1813
    limit {
        max_connections = 2048
        lifetime = 0
        idle_timeout = 30
    }
}

listen {
    type = auth
    ipaddr = 127.0.0.1
    port = 18120
    limit {
        max_connections = 10
        lifetime = 0
        idle_timeout = 10
    }
}

# Authorization section
authorize {
    # Pre-processing
    filter_username
    preprocess

    # Authentication methods
    chap
    mschap
    digest
    eap

    # User name manipulation
    suffix
    ntdomain

    # Database authentication
    sql

    # Additional checks
    expiration
    logintime

    # Remove SQL logging in production
    -sql_log

    # PAP authentication (fallback)
    pap
}

# Authentication section
authenticate {
    Auth-Type PAP {
        pap
    }

    Auth-Type CHAP {
        chap
    }

    Auth-Type MS-CHAP {
        mschap
    }

    Auth-Type Digest {
        digest
    }

    eap {
        eap
    }
}

# Pre-accounting section
preacct {
    preprocess
    acct_unique
}

# Accounting section
accounting {
    detail
    unix

    # SQL accounting
    sql

    # Accounting updates
    exec
    attr_filter.accounting_response
}

# Session section
session {
    sql
}

# Post-authentication section
post-auth {
    # Log successful and failed attempts
    sql

    # Execute post-auth scripts
    exec

    # Post-auth processing for rejects
    Post-Auth-Type REJECT {
        sql
        attr_filter.access_reject

        # Log rejection details
        exec
    }

    # Post-auth processing for Accept
    Post-Auth-Type Accept {
        # Add reply attributes if needed
        exec
    }
}

# Post-proxy section (for proxy RADIUS)
post-proxy {
    eap
}

# Pre-proxy section (for proxy RADIUS)
pre-proxy {
    eap
}