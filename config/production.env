# ===========================================
# Production Environment Configuration
# ===========================================
# This file contains production-ready environment settings
# Copy to .env and update with your actual values

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Session Secret (IMPORTANT: GENERATE NEW RANDOM SECRET FOR PRODUCTION!)
SESSION_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING_MINIMUM_64_CHARACTERS

# Database Configuration (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=kilusi_bill
POSTGRES_USER=kilusi_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_SSL=true
POSTGRES_POOL_MAX=50
POSTGRES_IDLE_TIMEOUT=60000
POSTGRES_CONNECTION_TIMEOUT=10000
POSTGRES_SSL_MODE=require

# RADIUS Configuration
RADIUS_HOST=localhost
RADIUS_USER=radius_user
RADIUS_PASSWORD=CHANGE_THIS_RADIUS_PASSWORD
RADIUS_DATABASE=radius
RADIUS_SERVER_ENABLED=true
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_AUTO_SYNC_ON_STARTUP=true
RADIUS_SYNC_INTERVAL_MINUTES=30

# RADIUS NAS Clients (JSON format)
RADIUS_NAS_CLIENTS=[
    {"ip": "192.168.88.1", "secret": "CHANGE_THIS_SECRET", "name": "Mikrotik Main"},
    {"ip": "192.168.88.2", "secret": "CHANGE_THIS_SECRET", "name": "Mikrotik Backup"}
]

# Application Settings
APP_MODE=radius
COMPANY_NAME=Your ISP Company
COMPANY_HEADER=YOUR DIGITAL NETWORK
FOOTER_INFO=Info Hubungi : +628XXXXXXXXXX
LOGO_FILENAME=kilusi-logo.svg
USER_AUTH_MODE=radius

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
ADMIN_NUMBERS=628XXXXXXXXXX

# Mikrotik Configuration
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=your_mikrotik_user
MIKROTIK_PASSWORD=CHANGE_THIS_MIKROTIK_PASSWORD
MIKROTIK_API_ENABLED=false

# SNMP Configuration
SNMP_HOST=192.168.88.1
SNMP_PORT=161
SNMP_COMMUNITY=CHANGE_THIS_SNMP_COMMUNITY
SNMP_VERSION=2c
SNMP_INTERFACE=sfp-sfpplus1
MAIN_INTERFACE=ether1-ISP
MONITOR_MODE=snmp
SNMP_MONITORING_ENABLED=true

# GenieACS Configuration
GENIEACS_URL=http://your-genieacs-server:7557
GENIEACS_USERNAME=admin
GENIEACS_PASSWORD=CHANGE_THIS_GENIEACS_PASSWORD

# WhatsApp Configuration
WHATSAPP_KEEP_ALIVE=true
WHATSAPP_RESTART_ON_ERROR=true
WA_SEND_DELAY_MS=3000
TECHNICIAN_NUMBERS=628XXXXXXXXXX,628XXXXXXXXXX
TECHNICIAN_GROUP_ID=1203630314957962xx@g.us

# Monitoring Configuration
PPPOE_MONITOR_ENABLE=true
PPPOE_MONITOR_INTERVAL_MINUTES=2
RX_POWER_WARNING=-26
RX_POWER_CRITICAL=-30
RX_POWER_NOTIFICATION_ENABLE=true
RX_POWER_WARNING_INTERVAL=1
RX_POWER_NOTIFICATION_INTERVAL_MINUTES=10

# Customer Portal
CUSTOMER_PORTAL_OTP=true
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10

# PPPoE Notifications
PPPOE_NOTIFICATIONS_ENABLED=true
PPPOE_LOGIN_NOTIFICATIONS=true
PPPOE_LOGOUT_NOTIFICATIONS=true
PPPOE_INCLUDE_OFFLINE_LIST=true
PPPOE_MAX_OFFLINE_LIST_COUNT=50

# OLT Monitoring
RXPOWER_RECAP_ENABLE=true
RXPOWER_RECAP_INTERVAL=12
OFFLINE_NOTIFICATION_ENABLE=true
OFFLINE_NOTIFICATION_INTERVAL=24

# Trouble Report
TROUBLE_REPORT_ENABLED=true
TROUBLE_REPORT_AUTO_TICKET=true
TROUBLE_REPORT_CATEGORIES=Internet Lambat,Tidak Bisa Browsing,WiFi Tidak Muncul,Koneksi Putus-Putus,Lainnya

# Billing Configuration
BILLING_AUTO_ISOLIR=true
BILLING_ISOLIR_PROFILE=ISOLIR
BILLING_ISOLIR_GRACE_DAYS=7
BILLING_ISOLIR_CHECK_INTERVAL=24
BILLING_MONTHLY_INVOICE_ENABLE=true
BILLING_MONTHLY_INVOICE_TIME=00:00
BILLING_MONTHLY_INVOICE_REMINDER_DAYS=7
BILLING_REMINDER_ENABLE=true
BILLING_REMINDER_TIME=08:00
BILLING_DUE_DATE=1
BILLING_GRACE_PERIOD=7
BILLING_DEVICE_SOURCE=mikrotik
AUTO_ISOLIR=true
PPPOE_USERNAME_SUFFIX=@your-isp.id

# Backup Configuration
BACKUP_INTERVAL_HOURS=12
BACKUP_MAX_FILES=30

# Payment Configuration
PAYMENT_ACCOUNTS=BRI XXXX XXXX XXXX XXXX a/n YOUR COMPANY NAME e-Wallet 081947215703 a/n YOUR COMPANY NAME
PAYMENT_GATEWAY_PROVIDER=tripay
TRIPAY_PRODUCTION=true

# API Configuration
API_KEY=CHANGE_THIS_API_KEY
API_SECRET=CHANGE_THIS_API_SECRET_MAKE_IT_LONG_AND_RANDOM

# Security Configuration
CORS_ORIGIN=https://yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12
HELMET_ENABLED=true
CORS_CREDENTIALS=false

# JWT Configuration
JWT_SECRET=CHANGE_THIS_JWT_SECRET_MAKE_IT_VERY_LONG_AND_RANDOM
JWT_EXPIRES_IN=24h

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/opt/kilusi-bill/uploads

# Google Maps Configuration (Optional)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email Configuration
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your_email@yourdomain.com
SMTP_PASSWORD=your_email_password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Kilusi Bill

# Logging Configuration
LOG_LEVEL=warn
LOG_DIR=/var/log/kilusi-bill
LOG_MAX_SIZE=50m
LOG_MAX_FILES=10

# Performance Configuration
ENABLE_METRICS=true
ENABLE_HEALTH_CHECK=true
CACHE_TTL=600

# SSL Configuration (if using HTTPS)
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/kilusi-bill.crt
SSL_KEY_PATH=/etc/ssl/private/kilusi-bill.key

# Development/Debug (set to false in production)
DEBUG=false
ENABLE_DEBUG_LOGS=false