# Documentation files (except README.md)
*.md
!README.md
!config-examples/README.md
!backend/README.md
!frontend/README.md

# Exclude all documentation from backend/scripts-extras
backend/scripts-extras/*.md
backend/docs/*.md
backend/freeradius-docker/docs/*.md

# Exclude changelog and progress files
CHANGELOG*
*MIGRATION*
*PROGRESS*
WORK_PROGRESS*
STATUS*
DIAGNOSTIC*
TROUBLESHOOTING*
GUIDE*
FAQ*

# Exclude test files and scripts
test-*.js
debug-*.js
check-*.js
create-*.js
fix-*.js
analyze-*.js
monitor-*.js
simple-*.js
reset-*.js
update-*.js
verify-*.js
setup-*.js
cleanup-*.js
backup-*.js
restore-*.js

# Exclude batch and shell scripts (except development scripts)
*.bat
!start-dev.bat
*.sh
!start-dev.sh
!docker/postgres/init/*.sh
!backend/freeradius-docker/scripts/*.sh

# Exclude configuration backups
*.conf.backup
*.config.backup
settings.json.backup
*.env.backup

# Documentation folder (exclude from git)
docs/