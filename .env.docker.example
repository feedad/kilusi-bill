# ===========================================
# Docker Environment Configuration
# ===========================================
# Copy this file to .env and update with your actual values

# PostgreSQL Configuration
POSTGRES_DB=kilusi_bill
POSTGRES_USER=kilusi_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_PORT=5432

# FreeRADIUS Configuration
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_ADMIN_PORT=18120

# PgAdmin Configuration (Optional)
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@yourcompany.com
PGADMIN_PASSWORD=your_pgadmin_password

# Database Connection (for application)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kilusi_bill
DB_USER=kilusi_user
DB_PASSWORD=your_postgres_password_here

# FreeRADIUS Connection (for application)
RADIUS_HOST=localhost
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RADIUS_SECRET=your_radius_secret_here